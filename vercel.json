{
  "version": 2,
  "builds": [
    { "src": "api/order.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/order", "dest": "/api/order.js" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/([^/]+\\.html)", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
